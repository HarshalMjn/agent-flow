{
  "name": "Translation Chain",
  "description": "Example workflow that translates input to French, then checks the length.",
  "nodes": [
    {
      "id": "node-1",
      "type": "input",
      "data": { "label": "Text Input", "type": "input", "config": { "value": "Hello, how are you today?" } },
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "node-2",
      "type": "llm",
      "data": { 
        "label": "Translate to French", 
        "type": "llm", 
        "config": { 
          "prompt": "Translate the following text to French: {{node-1}}", 
          "model": "gpt-4o" 
        } 
      },
      "position": { "x": 400, "y": 100 }
    },
    {
      "id": "node-3",
      "type": "logic",
      "data": { 
        "label": "Length Check", 
        "type": "logic", 
        "config": { "condition": "pass" } 
      },
      "position": { "x": 700, "y": 100 }
    }
  ],
  "edges": [
    { "id": "e1-2", "source": "node-1", "target": "node-2" },
    { "id": "e2-3", "source": "node-2", "target": "node-3" }
  ]
}
